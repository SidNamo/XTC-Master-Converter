{
  "name": "toxtc_node",
  "version": "1.0.0",
  "description": "XTC Master Converter",
  "author": "Namo",
  "repository": {
    "type": "git",
    "url": "https://github.com/SidNamo/XTC-Master-Converter.git"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win --x64 --ia32 --publish never",
    "build-mac": "electron-builder --mac --x64 --arm64 --universal --publish never",
    "postinstall": "cd epub-to-xtc-converter && npm install"
  },
  "build": {
    "appId": "com.namo.toxtc",
    "productName": "XTC_Master_Converter",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable",
      "artifactName": "${productName}-${version}-win-${arch}.${ext}",
      "requestedExecutionLevel": "asInvoker"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    },
    "files": [
      "**/*",
      "!dist/*",
      "!logs/*",
      "!temp/*",
      "!config.json",
      "!epub-to-xtc-converter/*"
    ],
    "extraResources": [
      {
        "from": "epub-to-xtc-converter",
        "to": "epub-to-xtc-converter",
        "filter": ["**/*"]
      }
    ],
    "asar": true
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "iconv-lite": "^0.7.2",
    "jschardet": "^3.1.4",
    "pdf-to-png-converter": "^3.18.0"
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^24.13.3"
  }
}
